# ==============================
# MAX Salon Bot — безопасный шаблон .env
# ==============================
#
# Как использовать:
# 1) Скопируйте файл:
#    cp .env.example .env
# 2) Заполните реальные значения.
# 3) Для первого запуска лучше оставить безопасные флаги:
#    MAX_SKIP_COMMANDS_SETUP=1
#    MAX_SKIP_STARTUP_PROBE=1
#
# Режимы запуска:
# - MAX_MODE=stdin   -> локальная проверка логики без реального MAX API
# - MAX_MODE=webhook -> рабочий режим через HTTP webhook
#
# --------------------------------------
# 1) БАЗОВЫЕ НАСТРОЙКИ БОТА
# --------------------------------------

# Токен бота MAX.
# ОБЯЗАТЕЛЬНО заполнить для реальной отправки сообщений.
MAX_BOT_TOKEN=f9LHodD0cOIQfZZCzIadbhS0AdbA7FMHozE83RwvbxygHyWpezvfMWwtFmWmMsENU-UpZoLL22RE8V67w7b6

# Режим запуска:
# stdin  - офлайн тестирование без внешнего API
# webhook - реальная работа через входящий webhook
MAX_MODE=webhook

# Таймаут HTTP-запросов к MAX API в секундах.
# Для безопасного старта лучше 8-10, а не 30+.
MAX_HTTP_TIMEOUT=8

# Если =1, исходящие запросы не отправляются в сеть,
# а только логируются. Очень удобно для отладки.
MAX_DRY_RUN=1

# --------------------------------------
# 2) БЕЗОПАСНЫЙ СТАРТ
# --------------------------------------

# Отключить попытку настроить команды бота при запуске.
# Рекомендуется оставить =1, пока не подтверждены точные endpoint-ы MAX API.
MAX_SKIP_COMMANDS_SETUP=1

# Отключить startup probe (например, getMe / проверка профиля бота).
# Рекомендуется оставить =1 на первом этапе.
MAX_SKIP_STARTUP_PROBE=1

# --------------------------------------
# 3) АВТОРИЗАЦИЯ ДЛЯ MAX API
# --------------------------------------

# Имя HTTP-заголовка авторизации.
# Обычно это Authorization.
MAX_AUTH_HEADER=Authorization

# Префикс токена.
# Часто используется Bearer.
# Если MAX API требует другой формат, измените.
MAX_AUTH_PREFIX=Bearer

# --------------------------------------
# 4) ENDPOINT-Ы MAX API
# --------------------------------------
# Можно использовать либо единый MAX_API_BASE_URL,
# либо задать отдельные URL ниже.
#
# ВАЖНО:
# Если вы ещё не уверены в точных endpoint-ах MAX,
# оставьте MAX_MODE=stdin и MAX_DRY_RUN=1.

# Базовый URL API MAX (если используется общий base URL).
# Пример-заглушка:
MAX_API_BASE_URL=https://example.max.bot.api

# Отдельные endpoint-ы. Если они заданы, код может использовать их напрямую.
# Ниже только ПРИМЕРЫ-ЗАГЛУШКИ — замените на реальные URL из документации MAX.
MAX_SEND_MESSAGE_URL=
MAX_EDIT_MESSAGE_URL=
MAX_ACK_ACTION_URL=
MAX_SET_COMMANDS_URL=
MAX_GET_ME_URL=

# --------------------------------------
# 5) WEBHOOK-СЕРВЕР
# --------------------------------------
# Нужны только если MAX_MODE=webhook.

MAX_WEBHOOK_HOST=0.0.0.0
MAX_WEBHOOK_PORT=8080
MAX_WEBHOOK_PATH=http://nsk7.bothost.ru/api/webhooks/github

# Секрет webhook-а, если MAX умеет подписывать запросы.
# Если не используется — оставить пустым.
MAX_WEBHOOK_SECRET=

# --------------------------------------
# 6) БАЗА ДАННЫХ И ЧАСОВОЙ ПОЯС
# --------------------------------------

TIMEZONE=Europe/Moscow
DATABASE_PATH=salon.db

# Список Telegram/внутренних ID администраторов через запятую.
# Для MAX вы можете оставить те же внутренние числовые ID,
# если ваши админские идентификаторы в входящих update совпадают по формату.
ADMIN_IDS=163589340,376017967

# --------------------------------------
# 7) ГОТОВЫЕ СЦЕНАРИИ ЗАПУСКА
# --------------------------------------
#
# A. Полностью безопасный локальный тест без сети:
# MAX_MODE=stdin
# MAX_DRY_RUN=1
# MAX_SKIP_COMMANDS_SETUP=1
# MAX_SKIP_STARTUP_PROBE=1
#
# B. Осторожный webhook-запуск:
# MAX_MODE=webhook
# MAX_DRY_RUN=0
# MAX_SKIP_COMMANDS_SETUP=1
# MAX_SKIP_STARTUP_PROBE=1
# MAX_WEBHOOK_HOST=0.0.0.0
# MAX_WEBHOOK_PORT=8080
# MAX_WEBHOOK_PATH=/max/webhook
# MAX_BOT_TOKEN=real_token
# MAX_SEND_MESSAGE_URL=https://REAL_MAX_API/.../sendMessage
#
# C. Полноценный боевой режим после подтверждения API:
# MAX_MODE=webhook
# MAX_DRY_RUN=0
# MAX_SKIP_COMMANDS_SETUP=0
# MAX_SKIP_STARTUP_PROBE=0
# MAX_SET_COMMANDS_URL=https://REAL_MAX_API/.../setMyCommands
# MAX_GET_ME_URL=https://REAL_MAX_API/.../getMe

