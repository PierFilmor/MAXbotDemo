# Готовый шаблон .env для запуска max_salon_bot.py на bothost
# Домен: http://nsk7.bothost.ru
#
# Как использовать:
# 1) Скопируйте файл:
#    cp .env.nsk7.example .env
# 2) Обязательно замените MAX_BOT_TOKEN на реальный токен.
# 3) Для первого запуска лучше оставить MAX_DRY_RUN=1.
# 4) После проверки webhook можно переключить MAX_DRY_RUN=0.

# --------------------------------------
# 1) БАЗОВЫЕ НАСТРОЙКИ
# --------------------------------------
MAX_BOT_TOKEN=f9LHodD0cOIQfZZCzIadbhS0AdbA7FMHozE83RwvbxygHyWpezvfMWwtFmWmMsENU-UpZoLL22RE8V67w7b6
MAX_MODE=webhook
MAX_HTTP_TIMEOUT=8

# Безопасный старт: бот не делает спорные запросы setMyCommands/getMe
MAX_DRY_RUN=1
MAX_SKIP_COMMANDS_SETUP=1
MAX_SKIP_STARTUP_PROBE=1

# --------------------------------------
# 2) АВТОРИЗАЦИЯ
# --------------------------------------
MAX_AUTH_HEADER=Authorization
MAX_AUTH_PREFIX=Bearer

# --------------------------------------
# 3) ENDPOINT-Ы MAX API
# --------------------------------------
# Если у вас есть только один base URL API MAX — укажите его здесь.
# Если точные endpoint-ы уже известны, лучше заполнить конкретные URL ниже.
MAX_API_BASE_URL=

# Рекомендуется явно задать хотя бы endpoint отправки сообщений,
# когда перейдёте из DRY_RUN в боевой режим.
MAX_SEND_MESSAGE_URL=
MAX_EDIT_MESSAGE_URL=
MAX_ACK_ACTION_URL=
MAX_SET_COMMANDS_URL=
MAX_GET_ME_URL=

# --------------------------------------
# 4) WEBHOOK НА BOTHOST
# --------------------------------------
# Локально приложение слушает 0.0.0.0:8080,
# а снаружи доступно по домену nsk7.bothost.ru.
MAX_WEBHOOK_HOST=0.0.0.0
MAX_WEBHOOK_PORT=3000
MAX_WEBHOOK_PATH=/api/webhooks/github

# Публичный адрес для логов и диагностики.
MAX_PUBLIC_BASE_URL=http://nsk7.bothost.ru
MAX_WEBHOOK_URL=http://nsk7.bothost.ru/api/webhooks/github

# Если MAX присылает подпись webhook, задайте секрет. Пока можно оставить пустым.
MAX_WEBHOOK_SECRET=

# --------------------------------------
# 5) БАЗА, ЧАСОВОЙ ПОЯС, АДМИНЫ
# --------------------------------------
TIMEZONE=Europe/Moscow
DATABASE_PATH=salon.db
ADMIN_IDS=163589340,376017967

# --------------------------------------
# 6) ПРИМЕЧАНИЯ
# --------------------------------------
# 1. 0.0.0.0 — это bind-адрес сервера, не внешний URL.
# 2. Пока MAX API точно не подтверждено, держите MAX_DRY_RUN=1.
# 3. Когда будете готовы отправлять реальные сообщения:
#    - установите MAX_DRY_RUN=0
#    - заполните MAX_SEND_MESSAGE_URL или MAX_API_BASE_URL
# 4. Если платформа bothost пробрасывает запросы на другой внутренний порт,
#    скорректируйте MAX_WEBHOOK_PORT.
